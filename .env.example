# "demo" serves pre-recorded fixture data — no API key needed, safe for evaluators.
# "live" calls the real Gemini API and requires GEMINI_API_KEY below.
APP_MODE=demo

# Gemini API key from https://aistudio.google.com/apikey. Only required when APP_MODE=live.
GEMINI_API_KEY=

# Gemini model used for extraction in live mode. "gemini-flash-latest" is a
# stable alias Google maintains pointing at their current recommended
# flash-tier model, so it keeps working as specific model versions (like the
# once-current "gemini-2.5-flash") get deprecated over time.
GEMINI_MODEL=gemini-flash-latest
